{
  "name": "cire",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bunx oxlint .",
    "format": "bunx oxfmt .",
    "format:check": "bunx oxfmt --check .",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:push": "bun run --cwd packages/db db:push",
    "db:push:remote": "bun run --cwd packages/db db:push:remote",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:reset": "bun run --cwd packages/db db:reset"
  },
  "devDependencies": {
    "lefthook": "^1.10.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.61.0"
  },
  "packageManager": "bun@1.3.5"
}
