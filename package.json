{
  "name": "osn",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "apps/*/web",
    "apps/*/ios",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint -c oxlintrc.json .",
    "check": "turbo check",
    "test": "turbo test --continue",
    "clean": "git clean -fdX",
    "fmt": "bunx --bun oxfmt apps packages '!**/*.{json,md,yml,yaml,css,html,astro}'",
    "fmt:check": "bunx --bun oxfmt apps packages '!**/*.{json,md,yml,yaml,css,html,astro}' --check",
    "reset": "bun run clean && bun i",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "lefthook install"
  },
  "overrides": {
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "bun-types": "latest",
    "lefthook": "^2.0.12",
    "oxfmt": "^0.20.0",
    "oxlint": "^0.16.0",
    "turbo": "^2.7.1",
    "typescript": "^5.7.0"
  }
}
