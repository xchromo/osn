{
  "name": "cire",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bunx oxlint .",
    "format": "bunx oxfmt .",
    "format:check": "bunx oxfmt --check .",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:push": "bun run --cwd packages/db db:push",
    "db:push:remote": "bun run --cwd packages/db db:push:remote",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:reset": "bun run --cwd packages/db db:reset"
  },
  "devDependencies": {
    "lefthook": "^1.13.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0"
  },
  "overrides": {
    "devalue": "^5.8.1",
    "esbuild": "^0.25.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "smol-toml": "^1.6.1",
    "vite": "^7.3.2"
  },
  "packageManager": "bun@1.3.5"
}
