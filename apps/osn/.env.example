# OSN Auth Server

# Server port
PORT=4000

# Database path (SQLite)
OSN_DATABASE_URL=../../data/osn.db

# WebAuthn configuration
OSN_RP_ID=localhost
OSN_RP_NAME=OSN
OSN_ORIGIN=http://localhost:5173

# Issuer URL (this server's public URL)
OSN_ISSUER_URL=http://localhost:4000

# JWT signing secret (at least 32 characters)
OSN_JWT_SECRET=change-me-to-a-secure-random-secret-at-least-32-chars

# Token TTLs (seconds)
OSN_ACCESS_TOKEN_TTL=3600
OSN_REFRESH_TOKEN_TTL=2592000

# Email provider (optional — set to enable OTP/magic link sending)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
