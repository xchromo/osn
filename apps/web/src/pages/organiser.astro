---
import '../styles/global.css'
import OrganiserView from '../components/OrganiserView'
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Organiser — Cire</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lato:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="mx-auto max-w-[1100px] px-8 py-12">
      <OrganiserView client:load apiUrl={import.meta.env.PUBLIC_API_URL} />
    </main>
  </body>
</html>
