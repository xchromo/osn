{
  "name": "osn-backend",
  "version": "1.0.50",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist",
    "db:pull": "bun drizzle-kit introspect:pg",
    "db:studio": "bun drizzle-kit studio",
    "db:migrate": "bun drizzle-kit generate:pg",
    "db:push": "bun run src/db/utils/migrate.ts",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run ./dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.3",
    "drizzle-valibot": "^0.2.0",
    "elysia": "latest",
    "pg": "^8.11.3",
    "valibot": "^0.30.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.3",
    "bun-types": "latest",
    "drizzle-kit": "^0.20.14"
  },
  "module": "dist/index.js"
}