# pulse/landing — marketing site build vars (all PUBLIC_*, baked in at build time).
# Copy to `.env` for local overrides; CI passes the production values at deploy.

# Pulse app — target of the primary "Find events" / "Get the app" CTA.
# Unset ⇒ the dev default in src/lib/site.ts (http://localhost:3001, the local
# Pulse app dev server). Prod value is the deployed Pulse app origin.
PUBLIC_APP_URL=http://localhost:3001
