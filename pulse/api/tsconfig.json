{
  "extends": "@shared/typescript-config/node.json",
  "compilerOptions": {
    "paths": {
      "#db": ["./src/db"],
      "#db/*": ["./src/db/*"],
      "#routes": ["./src/routes"],
      "#routes/*": ["./src/routes/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
