# SQLite database path. Use :memory: for an ephemeral in-memory DB (local dev).
# Omit or set to a file path for persistent storage.
DATABASE_URL=:memory:

# API server port (default: 3001)
# PORT=3001

# OSN JWT secret — must match the value configured in osn/api.
OSN_JWT_SECRET=change-me-to-a-secure-random-secret-at-least-32-chars

# OSN API base URL — used by the graph bridge for S2S calls.
OSN_API_URL=http://localhost:4000

# Shared secret for ARC key self-registration.
# Must match INTERNAL_SERVICE_SECRET in osn/api's environment.
# On startup, pulse-api generates an ephemeral P-256 key pair and calls
#   POST /graph/internal/register-service
# to register its public key with osn/api.
# Leave unset to skip registration (unit tests, CI without a live osn/api).
INTERNAL_SERVICE_SECRET=change-me-to-a-shared-random-secret

# Optional: pre-distribute a stable ARC private key for production.
# When set, the ephemeral key generation and self-registration steps are
# skipped; the matching public key must already be in osn/api's
# service_accounts table. Generate a fresh P-256 key pair with:
#   bunx --bun tsx osn/crypto/scripts/gen-arc-keypair.ts
# PULSE_API_ARC_PRIVATE_KEY=<private-key-jwk>
