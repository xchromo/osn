# SQLite database path. Use :memory: for an ephemeral in-memory DB (local dev).
# Omit or set to a file path for persistent storage.
DATABASE_URL=:memory:

# API server port (default: 3001)
# PORT=3001

# OSN API base URL — used by the graph bridge for S2S calls.
OSN_API_URL=http://localhost:4000

# ARC private key JWK for S2S authentication with osn/api.
# This dev key corresponds to the public key seeded in osn/db for service "pulse-api".
# Leave unset to use an ephemeral key (fine for unit tests; won't auth against a real osn/api).
# WARNING: dev-only key — never use in production. Generate a real pair for each environment.
PULSE_API_ARC_PRIVATE_KEY={"kty":"EC","crv":"P-256","x":"MKBCTNIcKUSDii11ySs3526iDZ8AiTo7Tu6KPAqv7D4","y":"4Etl6SRW2YiLUrN5vfvVHuhp7x8PxltmWWlbbM4IFyM","d":"870MB6gfuTJ4HtUnUvYMyJpr5eUZNP4Bk43bVdj3eX8"}
