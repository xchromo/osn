# osn/landing — marketing site build vars (all PUBLIC_*, baked in at build time).
# Copy to `.env` for local overrides; CI passes the production values at deploy.

# OSN identity / social app — target of the primary "Get started" CTA.
# Unset ⇒ the dev default in src/lib/site.ts (the local social dev server).
PUBLIC_APP_URL=http://localhost:1422

# Optional: docs / README link surfaced in the nav + footer.
# Unset ⇒ the default placeholder in src/lib/site.ts.
# PUBLIC_DOCS_URL=https://github.com/your-org/osn#readme
