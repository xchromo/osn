  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/local.ts",
    "dev:wrangler": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir ./dist",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
