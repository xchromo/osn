# OSN Auth Server

# Server port
PORT=4000

# Database path (SQLite)
OSN_DATABASE_URL=../../data/osn.db

# WebAuthn configuration
OSN_RP_ID=localhost
OSN_RP_NAME=OSN
OSN_ORIGIN=http://localhost:5173

# CORS-allowed app origins (comma-separated). Required in non-local envs.
# When unset in local dev, defaults to the monorepo frontend ports:
#   http://localhost:1420 (@pulse/app), http://localhost:1422 (@osn/social)
# OSN_CORS_ORIGIN=http://localhost:1420,http://localhost:1422

# Issuer URL (this server's public URL)
OSN_ISSUER_URL=http://localhost:4000

# JWT signing secret (at least 32 characters)
OSN_JWT_SECRET=change-me-to-a-secure-random-secret-at-least-32-chars

# Token TTLs (seconds)
OSN_ACCESS_TOKEN_TTL=3600
OSN_REFRESH_TOKEN_TTL=2592000

# Observability
# OSN_ENV=local                        # local | dev | staging | production (default: local)
# OSN_LOG_LEVEL=debug                  # trace | debug | info | warn | error | fatal (default: debug in local, info elsewhere)
# OTEL_EXPORTER_OTLP_ENDPOINT=         # OTLP HTTP endpoint (disabled if unset)
# OTEL_EXPORTER_OTLP_HEADERS=          # OTLP auth headers (key=value,key=value)
# OSN_TRACE_SAMPLE_RATIO=1.0           # 0.0–1.0 (default: 1.0 dev, 0.1 prod)

# Redis (optional — falls back to in-memory rate limiters)
# REDIS_URL=redis://localhost:6379
# REDIS_REQUIRED=false                 # true = exit if Redis fails to connect

# Email transport (Cloudflare Email Service REST API).
# In a non-local env (OSN_ENV=dev|staging|production) both of these are REQUIRED
# or the server throws at startup — UNLESS OSN_EMAIL_OPTIONAL is set (see below).
# In local dev they are unset and sends go to the in-memory log recorder.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_EMAIL_API_TOKEN=
# OSN_EMAIL_FROM=noreply@example.com   # verified sender address

# Degraded-email opt-in (non-secret boolean). Set truthy to let osn-api boot in
# a NON-LOCAL env WITHOUT the CLOUDFLARE_* creds, using a no-op transport that
# DISCARDS mail (transactional email is not delivered) and emits a loud startup
# warning, instead of throwing. Leave UNSET for the safe fail-closed default.
# Creds always win: if CLOUDFLARE_* are present this opt-in is ignored.
# OSN_EMAIL_OPTIONAL=true

# Shared secret for ARC key self-registration.
# pulse-api (and any other S2S service) calls POST /graph/internal/register-service
# on startup to register its public key. This secret authenticates that call.
# Must match INTERNAL_SERVICE_SECRET in each client service's environment.
# Leave unset to disable the registration endpoint (returns 501).
INTERNAL_SERVICE_SECRET=change-me-to-a-shared-random-secret

# Cloudflare Turnstile secret key (bot protection). KEY-OPTIONAL: when set,
# /register/begin and /login/passkey/begin REQUIRE a valid Turnstile token and
# fail-closed (reject on missing/invalid/duplicate). When unset (the default,
# both locally and in any tier), those gates are skipped and the flows behave
# exactly as before — safe to leave unset until the widget exists. This is the
# server half of the public PUBLIC_TURNSTILE_SITEKEY embedded in the organiser
# portal / osn-social builds. NEVER commit the value — in deployed tiers set it
# with `wrangler secret put TURNSTILE_SECRET_KEY` (see production-deploy runbook).
# TURNSTILE_SECRET_KEY=
