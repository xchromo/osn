{
  "name": "@zap/api",
  "version": "0.6.6",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/local.ts",
    "dev:wrangler": "wrangler dev --env dev",
    "build": "wrangler deploy --env dev --dry-run --outdir dist",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "types": "wrangler types",
    "check": "tsc --noEmit",
    "test": "bunx --bun vitest",
    "test:run": "bunx --bun vitest run",
    "test:d1": "bun test src/d1-integration.test.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@shared/crypto": "workspace:*",
    "@shared/observability": "workspace:*",
    "@shared/osn-auth-client": "workspace:*",
    "@shared/rate-limit": "workspace:*",
    "@zap/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.1",
    "@effect/vitest": "^0.29.0",
    "@shared/db-utils": "workspace:*",
    "@shared/typescript-config": "workspace:*",
    "jose": "^6.2.3",
    "miniflare": "^4.20260603.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0"
  }
}
