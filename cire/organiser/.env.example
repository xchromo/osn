# cire-api origin. PUBLIC_CIRE_API_URL is the canonical name; PUBLIC_API_URL is
# honoured as a legacy fallback (see src/lib/osn.ts). Dev default below;
# production builds set PUBLIC_CIRE_API_URL=https://api.cireweddings.com (baked
# in at build time — see .github/workflows/deploy.yml).
PUBLIC_API_URL=http://localhost:8787
# PUBLIC_CIRE_API_URL=https://api.cireweddings.com
# OSN identity (osn-api) issuer origin for organiser passkey sign-in. Dev
# default matches @osn/api on :4000. Production: https://id.cireweddings.com.
PUBLIC_OSN_ISSUER_URL=http://localhost:4000
# Guest invite (cire/web) origin. The "Preview invite" button opens this site
# with the wedding's host preview code pre-filled. Production:
# https://cireweddings.com.
PUBLIC_CIRE_WEB_URL=http://localhost:4321
