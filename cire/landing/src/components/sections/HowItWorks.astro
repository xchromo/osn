---
// The whole journey in three steps, read as a vertical sequence down the page
// (a hanging numeral in the margin, the step beside it), not three identical
// columns. The numerals are genuinely ordinal here, so they earn their place.
const steps = [
  {
    n: '01',
    title: 'Design your invitation',
    body:
      'Add your events, your wording and your guests, then theme it to your day. No design tools, no developers. It looks considered out of the box.',
  },
  {
    n: '02',
    title: 'Share one link',
    body:
      'Send a single link, or print a claim code on paper invites. Your guest list stays private, and guests never need an account.',
  },
  {
    n: '03',
    title: 'Watch the RSVPs roll in',
    body:
      'Replies, headcounts and dietary notes gather themselves on your dashboard. You stay on top of the day without lifting a spreadsheet.',
  },
] as const
---
<section
  id="how-it-works"
  class="border-border bg-surface/75 border-y px-6 py-24 md:py-32"
  aria-labelledby="how-heading"
>
  <div class="mx-auto max-w-[54rem]">
    <div class="mb-14 md:mb-20" data-reveal>
      <h2
        id="how-heading"
        class="display text-text text-[clamp(1.9rem,4.5vw,3rem)] leading-[1.2]"
      >
        From idea to invited in an afternoon.
      </h2>
    </div>

    <ol class="flex flex-col">
      {
        steps.map((step, i) => (
          <li
            class:list={[
              'grid grid-cols-[auto_1fr] items-baseline gap-x-6 gap-y-2 py-8 md:gap-x-12',
              i > 0 && 'border-border border-t',
            ]}
            data-reveal
          >
            <span
              class="display text-gold text-[2.5rem] leading-none font-light md:text-[3.25rem]"
              aria-hidden="true"
            >
              {step.n}
            </span>
            <div>
              <h3 class="display text-text mb-2 text-[1.5rem] font-normal">{step.title}</h3>
              <p class="font-body text-text-muted max-w-[38rem] text-[0.98rem] leading-[1.75] font-light">
                {step.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
