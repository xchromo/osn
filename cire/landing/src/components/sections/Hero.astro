---
// The face of the invitation. The whole first screen is the sealed letter: a
// real, three-dimensional wax seal resting at its heart, with the opening line
// and the calls to action set beneath it.
//
// Progressive enhancement is the rule here. Every word and both CTAs are
// server-rendered and painted immediately — the 3D seal (WaxSeal3D) is a purely
// decorative island layered in. No JS, no WebGL, or reduced motion: the seal is
// a flat gold disc and the page reads and converts exactly the same.
import { WaxSeal3D } from '../WaxSeal3D'
import { DEMO_ANCHOR, DEMO_INVITE_URL, IMAGES, ORGANISER_URL, unsplash } from '../../lib/site'

const demoHref = DEMO_INVITE_URL ?? DEMO_ANCHOR
const demoIsExternal = DEMO_INVITE_URL !== null
const hero = IMAGES.hero
---
<section
  class="relative flex min-h-[100svh] flex-col items-center justify-center overflow-hidden px-6 pt-28 pb-20 text-center"
  aria-label="Cire: invitations worthy of the moment"
>
  {/* Candle-warm celebration photo, dimmed under a forest radial so type and the
      seal stay legible. Eager: it is the hero's paint. */}
  <div class="absolute inset-0 -z-10">
    <img
      src={unsplash(hero.id, 2000)}
      srcset={[640, 1024, 1600, 2000].map((w) => `${unsplash(hero.id, w)} ${w}w`).join(', ')}
      sizes="100vw"
      alt={hero.alt}
      class="h-full w-full object-cover opacity-40"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: radial-gradient(120% 90% at 50% 32%, oklch(19.96% 0.0331 147.34 / 0.55), oklch(19.96% 0.0331 147.34 / 0.97));"
    >
    </div>
  </div>

  {/* The seal presenter — decorative, hydrates client-side, degrades to a poster. */}
  <div class="mb-10 md:mb-12">
    <WaxSeal3D client:load />
  </div>

  <div class="letter-column max-w-[46rem]">
    <p class="eyebrow mb-6">Bespoke digital wedding invitations</p>
    <h1 class="display text-text text-[clamp(2.6rem,8vw,5rem)] leading-[1.05]">
      Invitations worthy of the moment
    </h1>
    <p
      class="font-body text-text-muted mx-auto mt-7 max-w-[34rem] text-[1.05rem] leading-[1.7] font-light"
    >
      A real invitation: tactile, animated, personal. And it counts every RSVP, so you never chase a
      reply.
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href={ORGANISER_URL} class="cta-primary w-full sm:w-auto">
        Create your invitation
      </a>
      <a
        href={demoHref}
        target={demoIsExternal ? '_blank' : undefined}
        rel={demoIsExternal ? 'noopener noreferrer' : undefined}
        class="cta-ghost w-full sm:w-auto"
      >
        See a live invite
      </a>
    </div>
  </div>
</section>
