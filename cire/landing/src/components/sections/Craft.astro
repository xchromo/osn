---
// Trust + craft: privacy-first, your data is yours, no ads, no spam. Ties the
// product to the OSN identity story without getting technical.
import Figure from '../Figure.astro'
import { IMAGES } from '../../lib/site'

const points = [
  {
    title: 'Private by design',
    body: 'Guests claim a code — no public guest list, no link to forward, no enumeration. Your circle stays your circle.',
  },
  {
    title: 'No accounts for guests',
    body: 'Guests never sign up for anything. They open, they reply, they&rsquo;re done.',
  },
  {
    title: 'Your data is yours',
    body: 'No ads, no selling, no spam. The details guests trust you with are used for your day and nothing else.',
  },
] as const
---
<section class="px-6 py-12 md:py-20" aria-labelledby="craft-heading">
  <div class="mx-auto grid max-w-[64rem] items-center gap-10 md:grid-cols-2 md:gap-16">
    <div data-reveal>
      <Figure image={IMAGES.craft} class="aspect-[4/5]" />
    </div>
    <div data-reveal>
      <p class="font-body text-gold mb-4 text-[0.72rem] tracking-[0.28em] uppercase">
        Made with care
      </p>
      <h2
        id="craft-heading"
        class="font-display text-text mb-8 text-[clamp(1.9rem,4.5vw,3rem)] leading-[1.2] font-light italic"
      >
        The trust of paper, kept digital.
      </h2>
      <dl class="flex flex-col gap-6">
        {
          points.map((point) => (
            <div class="border-border border-t pt-5">
              <dt class="font-display text-text mb-1.5 text-[1.25rem] font-normal italic">
                {point.title}
              </dt>
              <dd class="font-body text-text-muted text-[0.95rem] leading-[1.7] font-light" set:html={point.body} />
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>
