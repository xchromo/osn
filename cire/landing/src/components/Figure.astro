---
// A hotlinked Unsplash image that always paints over a gold-tinted gradient, so
// a slow CDN or a blocked request never leaves an empty hole — the gradient is
// on-brand on its own. Responsive via srcset; lazy by default. Swap the `id`
// (or the whole IMAGES map in lib/site.ts) for real art when it exists.
import { unsplash, type SiteImage } from '../lib/site'

interface Props {
  image: SiteImage
  /** Extra classes for the wrapper (aspect ratio, rounding, etc.). */
  class?: string
  /** Eager-load above-the-fold figures; lazy for the rest (default). */
  eager?: boolean
  sizes?: string
}

const { image, class: klass = '', eager = false, sizes = '(min-width: 768px) 45vw, 100vw' } =
  Astro.props

const widths = [480, 800, 1200, 1600]
const srcset = widths.map((w) => `${unsplash(image.id, w)} ${w}w`).join(', ')
---
<figure
  class:list={['cire-figure', klass]}
  style="background: linear-gradient(150deg, var(--color-surface-raised), var(--color-surface));"
>
  <img
    src={unsplash(image.id, 1200)}
    srcset={srcset}
    sizes={sizes}
    alt={image.alt}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
    fetchpriority={eager ? 'high' : 'auto'}
  />
  <figcaption>{image.credit}</figcaption>
</figure>

<style>
  .cire-figure {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    margin: 0;
  }

  .cire-figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Photo credit, required by the Unsplash licence — present but visually quiet. */
  .cire-figure figcaption {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    color: var(--color-text);
    background: oklch(0% 0 0 / 0.45);
    padding: 0.15rem 0.45rem;
    border-radius: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .cire-figure:hover figcaption,
  .cire-figure:focus-within figcaption {
    opacity: 0.85;
  }
</style>
