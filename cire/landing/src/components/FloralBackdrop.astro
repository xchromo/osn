---
// Lowkey botanical backdrop — long trailing vines with leaves + small five-petal
// flowers, hand-drawn as a tiling SVG <pattern>. Muted sage greens (a touch
// lighter than --color-bg) at low opacity, so it reads as a faint etched field
// the page scrolls over rather than competing with the content. Fixed to the
// viewport, sits BEHIND content (z-index:-1, in front of the body's solid bg),
// decorative + non-interactive. The vine paths share the same x at the tile's
// top + bottom edges, so vertical tiling joins them into continuous long vines.
---
<div class="floral-backdrop" aria-hidden="true">
  <svg width="100%" height="100%" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      {/* A single leaf, stem at the origin, pointing "up". */}
      <path id="cire-leaf" d="M0 0 C 7 -9 8 -24 0 -34 C -8 -24 -7 -9 0 0 Z" />

      {/* A small five-petal flower with a faint gold heart. */}
      <g id="cire-flower">
        <g class="petals">
          <ellipse cx="0" cy="-6" rx="2.7" ry="5.4" />
          <ellipse cx="0" cy="-6" rx="2.7" ry="5.4" transform="rotate(72)" />
          <ellipse cx="0" cy="-6" rx="2.7" ry="5.4" transform="rotate(144)" />
          <ellipse cx="0" cy="-6" rx="2.7" ry="5.4" transform="rotate(216)" />
          <ellipse cx="0" cy="-6" rx="2.7" ry="5.4" transform="rotate(288)" />
        </g>
        <circle class="heart" cx="0" cy="0" r="2.3" />
      </g>

      <pattern id="cire-vines" width="320" height="460" patternUnits="userSpaceOnUse">
        {/* Vine A — left column. x=80 at both edges so it tiles seamlessly. */}
        <path class="vine" d="M80 0 C 120 115 40 230 80 345 C 100 405 70 450 80 460" />
        <use href="#cire-leaf" transform="translate(96 70) rotate(48) scale(0.9)" />
        <use href="#cire-leaf" transform="translate(58 150) rotate(-54) scale(0.85)" />
        <use href="#cire-leaf" transform="translate(98 250) rotate(42) scale(0.9)" />
        <use href="#cire-leaf" transform="translate(64 330) rotate(-40) scale(0.8)" />
        <use href="#cire-leaf" transform="translate(92 412) rotate(36) scale(0.78)" />
        <use href="#cire-flower" transform="translate(70 196) scale(1.05)" />
        <use href="#cire-flower" transform="translate(86 372) scale(0.9)" />

        {/* Vine B — right column. x=240 at both edges. */}
        <path class="vine" d="M240 0 C 200 120 280 240 240 360 C 215 420 255 450 240 460" />
        <use href="#cire-leaf" transform="translate(224 60) rotate(-50) scale(0.85)" />
        <use href="#cire-leaf" transform="translate(262 140) rotate(52) scale(0.9)" />
        <use href="#cire-leaf" transform="translate(226 250) rotate(-44) scale(0.88)" />
        <use href="#cire-leaf" transform="translate(258 340) rotate(46) scale(0.8)" />
        <use href="#cire-leaf" transform="translate(232 420) rotate(-36) scale(0.76)" />
        <use href="#cire-flower" transform="translate(254 196) scale(0.95)" />
        <use href="#cire-flower" transform="translate(232 300) scale(1.0)" />
      </pattern>
    </defs>

    <rect width="100%" height="100%" fill="url(#cire-vines)" />
  </svg>
</div>

<style>
  .floral-backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    /* Overall restraint — the colours below are already dim; this keeps the
       whole field a whisper behind the content. */
    opacity: 0.55;
  }

  .floral-backdrop svg {
    display: block;
  }

  /* Sage greens, a step lighter than --color-bg, at low alpha → faint etched look. */
  .vine {
    fill: none;
    stroke: oklch(52% 0.045 150 / 0.5);
    stroke-width: 1.5;
    stroke-linecap: round;
  }

  #cire-leaf {
    /* `<use>` inherits fill from the use site; set it once on the symbol. */
    fill: oklch(50% 0.05 150 / 0.34);
  }

  .petals ellipse {
    fill: oklch(62% 0.05 150 / 0.3);
  }

  .heart {
    fill: oklch(74.99% 0.0854 82.08 / 0.42);
  }

  /* On very small screens the tile is relatively large; nudge it fainter so it
     never crowds the copy. */
  @media (max-width: 640px) {
    .floral-backdrop {
      opacity: 0.42;
    }
  }
</style>
