---
// The back of the envelope. A sign-off statement that bookends the hero's seal:
// a small wax mark, the wordmark, the tagline. Below it the practical rows —
// section links and the legal pages (privacy / terms / refunds), which must be
// reachable from every page (privacy notice linked at point of collection).
import { ORGANISER_URL } from '../lib/site'

const year = 2026
---
<footer class="site-footer">
  <div class="site-footer__signoff">
    <span class="site-footer__seal" aria-hidden="true">C</span>
    <p class="site-footer__wordmark">Cire</p>
    <p class="site-footer__tagline">Invitations worthy of the moment.</p>
  </div>

  <hr class="rule-gold site-footer__rule" />

  <div class="site-footer__rows">
    <nav class="site-footer__nav" aria-label="Sections">
      <a href="/#how-it-works">How it works</a>
      <a href="/#features">What&rsquo;s inside</a>
      <a href="/#faq">Questions</a>
      <a href={ORGANISER_URL}>Create an invitation</a>
    </nav>

    <div class="site-footer__legal">
      <nav aria-label="Legal">
        <a href="/privacy">Privacy Notice</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms">Terms</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/refunds">Refunds</a>
      </nav>
      <p class="site-footer__copy">&copy; {year} Cire. Made with care.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border, rgba(255, 255, 255, 0.1));
    padding: 4.5rem 1.5rem 3rem;
    font-family: var(--font-body, "Lato", system-ui, sans-serif);
    color: var(--color-text-muted, rgba(255, 255, 255, 0.5));
  }

  .site-footer__signoff {
    text-align: center;
    max-width: 64rem;
    margin: 0 auto;
  }

  /* A small wax mark that rhymes with the hero seal, closing the loop. */
  .site-footer__seal {
    display: inline-grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    font-family: var(--font-display, "Cormorant Garamond", Georgia, serif);
    font-style: italic;
    font-size: 1.9rem;
    color: oklch(30% 0.04 80);
    background: radial-gradient(
      circle at 38% 32%,
      oklch(82% 0.09 82.08),
      oklch(63% 0.085 70) 68%,
      oklch(52% 0.08 64)
    );
    box-shadow:
      inset 0 2px 4px oklch(95% 0.05 82 / 0.5),
      inset 0 -3px 7px oklch(40% 0.06 60 / 0.6);
    margin-bottom: 1.25rem;
  }

  .site-footer__wordmark {
    font-family: var(--font-display, "Cormorant Garamond", Georgia, serif);
    font-size: 2.25rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--color-gold, oklch(74.99% 0.0854 82.08));
    margin: 0 0 0.4rem;
  }

  .site-footer__tagline {
    font-size: 0.95rem;
    margin: 0;
  }

  .site-footer__rule {
    max-width: 64rem;
    margin: 3rem auto;
  }

  .site-footer__rows {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem 3rem;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.75rem;
    font-size: 0.875rem;
  }

  .site-footer__legal {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.8125rem;
  }

  .site-footer__legal nav {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-footer__copy {
    margin: 0;
  }

  @media (min-width: 640px) {
    .site-footer__legal {
      align-items: flex-end;
      text-align: right;
    }
  }

  .site-footer a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 0.2s var(--ease-out, ease),
      border-color 0.2s var(--ease-out, ease);
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--color-gold, oklch(74.99% 0.0854 82.08));
    border-bottom-color: currentColor;
  }

  .site-footer a:focus-visible {
    outline: 2px solid var(--color-gold, oklch(74.99% 0.0854 82.08));
    outline-offset: 3px;
    border-radius: 0.125rem;
  }
</style>
