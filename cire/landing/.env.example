# cire/landing — marketing site build vars (all PUBLIC_*, baked in at build time).
# Copy to `.env` for local overrides; CI passes the production values in deploy.yml.

# Organiser portal — target of the primary "Create your invitation" CTA.
# End-state prod value is https://host.cireweddings.com (see the migration plan
# in wiki/apps/cire-landing.md). Unset ⇒ the dev default in src/lib/site.ts.
PUBLIC_ORGANISER_URL=http://localhost:4322

# Optional: a real seeded demo invitation for the "See a live invite" CTA.
# Unset ⇒ the CTA scrolls to the in-page interactive (no-op) demo instead.
# PUBLIC_DEMO_INVITE_URL=https://cireweddings.com/cire-wedding?code=DEMO-IVY-AA11
