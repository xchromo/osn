---
// Bare-domain (`/`) route. Resolves the deployment's primary wedding WITHOUT a
// build-time slug variable and redirects to its clean path (`/<slug>`), so the
// main link (`https://cireweddings.com/`) stays clean while the SSR'd invite
// lives at the per-wedding path. The `?code=<host code>` deep-link is preserved
// across the redirect so a bare-domain preview link still auto-claims.
//
//  - exactly one wedding → 302 → `/<slug>`
//  - several weddings    → 302 → `/<slug>` of the most-recently-created (the API
//                          decides; documented limitation)
//  - no wedding          → neutral "no invitation configured" state (never a crash)
//  - API unreachable     → same neutral state (transient — no redirect loop)
import { fetchPrimaryWedding } from '../lib/invite'
import NotFoundDocument from '../components/NotFoundDocument.astro'

const primary = await fetchPrimaryWedding()

if (primary.kind === 'ok') {
  // Carry any `?code=` (and other query) through to the per-wedding path so a
  // bare-domain preview deep-link still auto-claims after the redirect.
  const target = `/${encodeURIComponent(primary.slug)}${Astro.url.search}`
  return Astro.redirect(target, 302)
}
---
<NotFoundDocument
  heading={primary.kind === 'none' ? 'No invitation configured' : 'Invitation unavailable'}
  body={
    primary.kind === 'none'
      ? 'There is no invitation set up at this address yet. If you have an invite link, please open that link directly.'
      : "We couldn't load the invitation right now. Please try again in a moment, or open your invite link directly."
  }
/>
